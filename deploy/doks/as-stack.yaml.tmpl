apiVersion: v1
kind: Namespace
metadata:
  name: ${AS_NAMESPACE}
---
apiVersion: v1
kind: Secret
metadata:
  name: as-runtime-secret
  namespace: ${AS_NAMESPACE}
type: Opaque
stringData:
  AS_RUNTIME_DATABASE_URL: "${AS_RUNTIME_DATABASE_URL}"
  AS_FLOWERSHOW_AWS_ACCESS_KEY_ID: "${AS_FLOWERSHOW_AWS_ACCESS_KEY_ID}"
  AS_FLOWERSHOW_AWS_SECRET_ACCESS_KEY: "${AS_FLOWERSHOW_AWS_SECRET_ACCESS_KEY}"
  AS_FLOWERSHOW_SESSION_SECRET: "${AS_FLOWERSHOW_SESSION_SECRET}"
  AS_FLOWERSHOW_COGNITO_ADMIN_EMAILS: "${AS_FLOWERSHOW_COGNITO_ADMIN_EMAILS}"
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: as-runtime-config
  namespace: ${AS_NAMESPACE}
data:
  AS_REPO_ROOT: /app
  AS_BASE_DOMAIN: "${AS_BASE_DOMAIN}"
  AS_REGISTRY_HOST: "${AS_REGISTRY_HOST}"
  AS_GITHUB_URL: "${AS_GITHUB_URL}"
  AS_BOOT_EXECUTION_ENABLED: "true"
  AS_WEBD_ADDR: ":8090"
  AS_APID_ADDR: ":8092"
  AS_REGISTRYD_ADDR: ":8093"
  AS_MATERIALIZER_ADDR: ":8091"
  AS_EXECD_ADDR: ":8094"
  AS_EXECD_REGISTRY_BASE_URL: "http://as-registryd.${AS_NAMESPACE}.svc.cluster.local"
  AS_EXECD_PUBLIC_API_BASE_URL: "http://as-apid.${AS_NAMESPACE}.svc.cluster.local"
  AS_EXECD_INTERNAL_API_BASE_URL: "http://as-apid.${AS_NAMESPACE}.svc.cluster.local"
  AS_EXECUTION_HEALTH_TIMEOUT_SECONDS: "180"
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: as-apid
  namespace: ${AS_NAMESPACE}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: as-apid
  template:
    metadata:
      labels:
        app: as-apid
    spec:
      imagePullSecrets:
        - name: ${AS_IMAGE_PULL_SECRET}
      containers:
        - name: apid
          image: ${AS_IMAGE}
          imagePullPolicy: Always
          command: ["/usr/local/bin/apid"]
          ports:
            - containerPort: 8092
              name: http
          envFrom:
            - configMapRef:
                name: as-runtime-config
            - secretRef:
                name: as-runtime-secret
          env:
            - name: AS_RUNTIME_AUTO_MIGRATE
              value: "true"
          readinessProbe:
            httpGet:
              path: /v1/runtime/health
              port: http
            initialDelaySeconds: 5
            periodSeconds: 5
          livenessProbe:
            httpGet:
              path: /v1/runtime/health
              port: http
            initialDelaySeconds: 15
            periodSeconds: 10
          resources:
            requests:
              cpu: 100m
              memory: 128Mi
            limits:
              cpu: 500m
              memory: 512Mi
---
apiVersion: v1
kind: Service
metadata:
  name: as-apid
  namespace: ${AS_NAMESPACE}
spec:
  type: ClusterIP
  selector:
    app: as-apid
  ports:
    - name: http
      port: 80
      targetPort: http
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: as-registryd
  namespace: ${AS_NAMESPACE}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: as-registryd
  template:
    metadata:
      labels:
        app: as-registryd
    spec:
      imagePullSecrets:
        - name: ${AS_IMAGE_PULL_SECRET}
      containers:
        - name: registryd
          image: ${AS_IMAGE}
          imagePullPolicy: Always
          command: ["/usr/local/bin/registryd"]
          ports:
            - containerPort: 8093
              name: http
          envFrom:
            - configMapRef:
                name: as-runtime-config
            - secretRef:
                name: as-runtime-secret
          env:
            - name: AS_RUNTIME_AUTO_MIGRATE
              value: "false"
          readinessProbe:
            httpGet:
              path: /healthz
              port: http
            initialDelaySeconds: 5
            periodSeconds: 5
          livenessProbe:
            httpGet:
              path: /healthz
              port: http
            initialDelaySeconds: 15
            periodSeconds: 10
          resources:
            requests:
              cpu: 100m
              memory: 128Mi
            limits:
              cpu: 500m
              memory: 512Mi
---
apiVersion: v1
kind: Service
metadata:
  name: as-registryd
  namespace: ${AS_NAMESPACE}
spec:
  type: ClusterIP
  selector:
    app: as-registryd
  ports:
    - name: http
      port: 80
      targetPort: http
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: as-webd
  namespace: ${AS_NAMESPACE}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: as-webd
  template:
    metadata:
      labels:
        app: as-webd
    spec:
      imagePullSecrets:
        - name: ${AS_IMAGE_PULL_SECRET}
      containers:
        - name: webd
          image: ${AS_IMAGE}
          imagePullPolicy: Always
          command: ["/usr/local/bin/webd"]
          ports:
            - containerPort: 8090
              name: http
          envFrom:
            - configMapRef:
                name: as-runtime-config
            - secretRef:
                name: as-runtime-secret
          env:
            - name: AS_RUNTIME_AUTO_MIGRATE
              value: "false"
          readinessProbe:
            httpGet:
              path: /
              port: http
            initialDelaySeconds: 5
            periodSeconds: 5
          livenessProbe:
            httpGet:
              path: /
              port: http
            initialDelaySeconds: 15
            periodSeconds: 10
          resources:
            requests:
              cpu: 100m
              memory: 128Mi
            limits:
              cpu: 500m
              memory: 512Mi
        - name: execd
          image: ${AS_IMAGE}
          imagePullPolicy: Always
          command: ["/usr/local/bin/execd"]
          ports:
            - containerPort: 8094
              name: execd-http
          envFrom:
            - configMapRef:
                name: as-runtime-config
            - secretRef:
                name: as-runtime-secret
          env:
            - name: AS_RUNTIME_AUTO_MIGRATE
              value: "false"
            - name: AS_EXECUTION_REMEDIATION_TARGET
              value: "main"
            - name: AS_EXECUTION_REMEDIATION_HINT
              value: "Fix the realization, open a PR, and relaunch once merged."
          readinessProbe:
            httpGet:
              path: /healthz
              port: execd-http
            initialDelaySeconds: 5
            periodSeconds: 5
          livenessProbe:
            httpGet:
              path: /healthz
              port: execd-http
            initialDelaySeconds: 15
            periodSeconds: 10
          resources:
            requests:
              cpu: 100m
              memory: 128Mi
            limits:
              cpu: 500m
              memory: 512Mi
---
apiVersion: v1
kind: Service
metadata:
  name: as-webd
  namespace: ${AS_NAMESPACE}
spec:
  type: ClusterIP
  selector:
    app: as-webd
  ports:
    - name: http
      port: 80
      targetPort: http
---
