          command: ["/usr/local/bin/materializerd"]
          ports:
            - containerPort: 8091
              name: http
          envFrom:
            - configMapRef:
                name: as-runtime-config
          readinessProbe:
            httpGet:
              path: /healthz
              port: http
            initialDelaySeconds: 5
            periodSeconds: 5
          livenessProbe:
            httpGet:
              path: /healthz
