.DS_Store
.claude/

# Local docs/packages
/plans/*.zip

# Local binaries — kernel services
/kernel/bin/
/kernel/kernel/
/kernel/asvalidate
/kernel/materializerd
/kernel/webd

# Realization Go build artifacts.
# Runtime uses `go run .` so these don't normally appear, but if someone
# runs `go build` inside an app dir the binary lands next to go.mod.
# Ignore any extensionless executable in an artifacts subtree.
/seeds/**/artifacts/**/[!.]?*[!.]*
!/seeds/**/artifacts/**/*.*
!/seeds/**/artifacts/**/

# Local hydrated/materialized state
/materialized/

# Local Postgres overrides
/.env.postgres

# Local deployment config and rendered manifests
/.deployment_config/
